+void InputMethod::commitText(const QString &text)
+{
+    if (text.isEmpty()) {
+        return;
+    }
+    // Same entry point the zwp_input_method_v1 context's commitString signal is
+    // wired to (see adoptInputMethodContext): KWin decides how to deliver it.
+    commitString(m_serial++, text);
+}
